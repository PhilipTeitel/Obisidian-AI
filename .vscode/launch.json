{
  "configurations": [
    {
      "name": "Attach to Obsidian",
      "type": "chrome",
      "request": "attach",
      "port": 9229,
      "address": "127.0.0.1",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "resolveSourceMapLocations": ["**", "!**/node_modules/**"],
      "sourceMapPathOverrides": {
        "../../*": "${workspaceFolder}/**"
      }
    },{
      "type": "node",
      "name": "Attach: Obsidian AI sidecar",
      "request": "attach",
      "port": 62127,
      "cwd": "${workspaceFolder}",
      "sourceMaps": true,
      "resolveSourceMapLocations": ["**", "!**/node_modules/**"],
      "sourceMapPathOverrides": {
        "../..": "${workspaceFolder}/*"
      },
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    }
  ]
}
