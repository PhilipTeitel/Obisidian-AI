{
  "configurations": [
    {
      "type": "pwa-node",
      "name": "Attach: Obsidian AI sidecar",
      "request": "attach",
      "port": 62127,
      "cwd": "${workspaceFolder}",
      "outFiles": [
        "${workspaceFolder}/dist/sidecar/**/*.cjs",
        "${workspaceFolder}/dist/sidecar/**/*.map",
        "**/plugins/obsidian-ai/sidecar/**/*.cjs",
        "**/plugins/obsidian-ai/sidecar/**/*.map"
      ],
      "resolveSourceMapLocations": ["**", "!**/node_modules/**"],
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    }
  ]
}
