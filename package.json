{
  "name": "obsidian-ai-mvp",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Obsidian AI plugin (iteration 2) — plugin + Node sidecar. See README.md.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm run build:plugin && npm run build:sidecar",
    "build:plugin": "node esbuild.config.mjs",
    "build:sidecar": "node esbuild.sidecar.mjs",
    "typecheck": "tsc -p tsconfig.core.json --noEmit && tsc -p tsconfig.plugin.json --noEmit && tsc -p tsconfig.sidecar.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run tests/core tests/plugin",
    "test:integration": "vitest run tests/sidecar",
    "verify:plugin-bundle": "node scripts/verify-plugin-bundle.mjs",
    "verify:stack": "node scripts/verify-stack.mjs",
    "check:boundaries": "node scripts/check-source-boundaries.mjs",
    "verify:core-imports": "node scripts/check-core-imports.mjs",
    "smoke:sidecar": "node dist/sidecar/server.cjs",
    "dev": "node scripts/dev.mjs",
    "deploy:plugin": "node scripts/deploy-plugin.mjs",
    "deploy:sidecar": "node scripts/deploy-sidecar.mjs",
    "dev:plugin": "node esbuild.config.mjs --watch",
    "dev:sidecar": "node esbuild.sidecar.mjs --watch"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^16.0.0",
    "happy-dom": "^15.11.7",
    "obsidian": "^1.7.2",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.29.0",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "better-sqlite3": "^12.8.0",
    "mdast-util-to-string": "^4.0.0",
    "pino": "^10.3.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "sqlite-vec": "^0.1.9",
    "unified": "^11.0.5",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  }
}
