{
  "name": "obsidian-ai-mvp",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Obsidian AI plugin (iteration 2) — plugin + Node sidecar. See README.md.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm run build:plugin && npm run build:sidecar",
    "build:plugin": "node esbuild.config.mjs",
    "build:sidecar": "node esbuild.sidecar.mjs",
    "typecheck": "tsc -p tsconfig.core.json --noEmit && tsc -p tsconfig.plugin.json --noEmit && tsc -p tsconfig.sidecar.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "verify:plugin-bundle": "node scripts/verify-plugin-bundle.mjs",
    "check:boundaries": "node scripts/check-source-boundaries.mjs",
    "verify:core-imports": "node scripts/check-core-imports.mjs",
    "smoke:sidecar": "node dist/sidecar/server.js",
    "dev": "node scripts/dev.mjs",
    "dev:plugin": "node esbuild.config.mjs --watch",
    "dev:sidecar": "node esbuild.sidecar.mjs --watch"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^22.14.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^16.0.0",
    "obsidian": "^1.7.2",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.29.0",
    "vitest": "^3.1.1"
  }
}
